# Configuração do Servidor
PORT=3001
NODE_ENV=development

# Banco de Dados
DATABASE_PATH=src/db/copy_generator.db

# API de Inteligência Artificial (Gemini)
# Obtenha sua chave em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=sua_chave_do_gemini_aqui

# CORS — Origem Permitida (para produção)
# Em desenvolvimento, deixe em branco (aceita qualquer origem).
# Em produção, coloque o domínio do seu frontend: ex: https://meufrontend.com
# CORS_ORIGIN=https://meufrontend.com
